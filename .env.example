# ===== Telegram =====
# Create a bot via @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Your personal chat id (message @userinfobot to find yours).
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ===== LLM (configurable provider) =====
# Which provider to use for the main brief: "openai" or "anthropic".
LLM_PROVIDER=openai
# API key for the provider above. PLACEHOLDER — replace before running.
LLM_API_KEY=your-llm-api-key
# Model used for all four sections of the brief.
LLM_MODEL=gpt-4o-mini
# Optional: route ONLY section 3 (unbiased grading) to a different model.
# Leave blank to use the same model as LLM_MODEL.
GRADER_MODEL=

# ===== OpenAI (optional — enables Whisper transcription fallback) =====
# Used when a video has NO captions: audio is downloaded (through the proxy)
# and transcribed via OpenAI's whisper-1 API ($0.006/min). Get a key at
# platform.openai.com/api-keys. Leave blank to skip caption-less videos.
# Falls back to OPENAI_API_KEY if OPENAI_TRANSCRIBE_KEY is unset.
OPENAI_TRANSCRIBE_KEY=

# ===== Proxy (optional — needed if YouTube blocks your host's IP) =====
# Residential proxy URL for yt-dlp. Dodges YouTube's "confirm you're not a bot"
# wall on datacenter IPs (Railway/AWS/etc.). Format:
#   http://user:pass@geo.iproyal.com:12321
# Get one at iproyal.com (pay-as-you-go ~$7/GB; actual usage is tiny).
PROXY_URL=

# ===== Railway IDs (for /add persisting channel list back to CONFIG_YAML) =====
# Only needed if you want /add to persist channels to Railway. Find these in
# the Railway dashboard URL or via `railway status`.
RAILWAY_PROJECT_ID=
RAILWAY_SERVICE_NAME=mindmonk-digest-glm5.2
RAILWAY_ENVIRONMENT=production

# ===== Logging (optional) =====
# LOG_FORMAT=json  (default; structured JSON for production)
# LOG_FORMAT=text  (human-readable for local dev)

# ===== Paths (optional overrides) =====
# CONFIG_PATH=config.yaml
# PROFILE_PATH=profile.yaml
# DB_PATH=podcast-digest.db
